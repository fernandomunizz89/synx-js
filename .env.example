# SYNX environment variables
# Copy this file to .env and fill real API keys before running the CLI.
# Do NOT commit your .env file to source control.

# OpenAI-compatible provider (required for OpenAI / OpenRouter / custom endpoints)
AI_AGENTS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_AGENTS_OPENAI_API_KEY=sk-your-openai-key

# Google Generative AI (Gemini/PaLM)
AI_AGENTS_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_AGENTS_GOOGLE_API_KEY=AIza-your-google-key

# Anthropic Claude Code
AI_AGENTS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_AGENTS_ANTHROPIC_API_KEY=sk-your-anthropic-key

# LM Studio (local)
AI_AGENTS_LMSTUDIO_BASE_URL=http://127.0.0.1:1234
AI_AGENTS_LMSTUDIO_API_KEY=lmstudio-local-key
