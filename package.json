{
  "name": "synx",
  "version": "5.0.0",
  "private": true,
  "description": "SYNX cyber-orchestrator CLI for guided, file-driven multi-agent execution",
  "type": "module",
  "bin": {
    "synx": "./bin/synx.js",
    "ai-agents": "./bin/ai-agents.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "cypress:run": "cypress run --config-file cypress.config.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "boxen": "^8.0.1",
    "cli-spinners": "^3.4.0",
    "commander": "^12.1.0",
    "gradient-string": "^3.0.0",
    "log-update": "^7.2.0",
    "string-width": "^8.2.0",
    "strip-ansi": "^7.2.0",
    "wrap-ansi": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "cypress": "^15.12.0",
    "eslint": "^10.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
